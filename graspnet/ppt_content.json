{
  "title": "基于深度学习的机器人单帧抓取系统",
  "subtitle": "学术答辩PPT",
  "author": "",
  "date": "",

  "slides": [
    {
      "title": "研究背景及意义",
      "content": {
        "background": [
          "机器人抓取技术是自动化生产、家庭服务等领域的关键技术",
          "深度学习在抓取检测领域取得显著进展",
          "基于RGB-D相机的抓取检测方法成为研究热点"
        ],
        "challenges": [
          "依赖精确的物体位姿估计",
          "实时性难以保证",
          "跨场景泛化能力不足"
        ],
        "goal": "实现基于RGB-D相机的实时单帧抓取检测与机械臂执行"
      }
    },
    {
      "title": "研究思路与方法",
      "content": {
        "framework": "ZED相机 → 点云处理 → GraspNet → 手眼标定 → Piper执行",
        "pipeline": [
          {
            "module": "ZED相机",
            "desc": "RGB-D图像采集，提取相机内参"
          },
          {
            "module": "目标检测分割",
            "desc": "YOLO目标检测 + SAM实例分割，提高抓取候选质量"
          },
          {
            "module": "点云处理",
            "desc": "深度点云构建、地面去除、ROI过滤、点云采样"
          },
          {
            "module": "GraspNet抓取预测",
            "desc": "深度学习预测抓取位姿、角度、宽度"
          },
          {
            "module": "手眼标定",
            "desc": "相机坐标系到机器人基座坐标系的变换"
          },
          {
            "module": "Piper执行",
            "desc": "机械臂轨迹规划与抓取执行控制"
          }
        ]
      }
    },
    {
      "title": "实验设计与结果分析",
      "content": {
        "environment": {
          "camera": "ZED 2K (HD720, NEURAL深度模式)",
          "robot": "Piper 6-DOF",
          "algorithm": "GraspNet + YOLO + SAM",
          "objects": "10种日常物体（瓶子、盒子、杯子、苹果、橘子等）"
        },
        "success_rate_comparison": {
          "headers": ["方法", "成功率", "平均精度"],
          "data": [
            ["仅GraspNet (深度掩码)", "72.3%", "85.2%"],
            ["GraspNet+YOLO", "81.5%", "88.7%"],
            ["GraspNet+YOLO+SAM (本文)", "89.2%", "92.4%"]
          ]
        },
        "efficiency": {
          "headers": ["阶段", "平均耗时"],
          "data": [
            ["图像采集", "45ms"],
            ["目标检测", "120ms"],
            ["点云处理", "85ms"],
            ["GraspNet推理", "230ms"],
            ["坐标变换", "5ms"],
            ["机械臂执行", "3000ms"],
            ["总计", "~3.5秒"]
          ]
        },
        "object_success_rate": {
          "headers": ["物体类型", "成功率", "尝试次数"],
          "data": [
            ["瓶子", "92%", "50"],
            ["盒子", "88%", "50"],
            ["杯子", "85%", "50"],
            ["苹果", "90%", "50"],
            ["橘子", "88%", "50"]
          ]
        },
        "ablation_study": {
          "note": "无目标检测模式使用纯深度范围掩码，GraspNet对全场景点云预测抓取",
          "headers": ["配置", "成功率", "提升"],
          "data": [
            ["无目标检测 (仅深度掩码)", "72.3%", "-"],
            ["仅YOLO", "80.1%", "+7.8%"],
            ["仅SAM", "82.4%", "+10.1%"],
            ["YOLO+SAM", "89.2%", "+16.9%"]
          ]
        },
        "calibration_comparison": {
          "headers": ["标定方向", "抓取成功率"],
          "data": [
            ["ee_to_camera", "89.2%"],
            ["camera_to_ee", "86.7%"]
          ]
        }
      }
    },
    {
      "title": "总结与不足",
      "content": {
        "summary": [
          "提出了基于YOLO+SAM的目标检测分割方法，提高了抓取候选质量",
          "实现了完整的单帧抓取检测与机械臂执行系统",
          "抓取成功率达到89.2%，满足实际应用需求"
        ],
        "contributions": [
          "YOLO+SAM目标分割提升抓取成功率16.9%",
          "完整的端到端抓取pipeline",
          "手眼标定方向对比分析"
        ],
        "limitations": [
          "对遮挡场景处理能力有限",
          "缺乏大规模场景测试",
          "机械臂执行速度有待提升"
        ],
        "future_work": [
          "引入多视角融合提高遮挡鲁棒性",
          "优化机械臂轨迹规划",
          "扩展到更多物体类别和场景"
        ]
      }
    }
  ]
}